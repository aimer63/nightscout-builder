# =============================================================================
# CGM-Remote-Monitor Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control (it contains secrets)

# -----------------------------------------------------------------------------
# REQUIRED SETTINGS
# -----------------------------------------------------------------------------

# API_SECRET: A secret passphrase for admin access (minimum 12 characters)
# This is used for authentication and should be strong and unique
API_SECRET=change_me_to_at_least_12_characters

# -----------------------------------------------------------------------------
# DATABASE SETTINGS
# -----------------------------------------------------------------------------

# MongoDB connection string
# Default uses the mongo container in docker-compose.yml
# If using external MongoDB, update this accordingly
MONGO_CONNECTION=mongodb://mongo:27017/nightscout

# MongoDB data directory on host (for persistent storage)
NS_MONGO_DATA_DIR=./mongo-data

# -----------------------------------------------------------------------------
# SERVER SETTINGS
# -----------------------------------------------------------------------------

# Port to expose Nightscout on (change if 1337 is in use)
NS_PORT=1337

# Timezone for display (see: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones)
NS_TZ=Europe/Rome

# -----------------------------------------------------------------------------
# FEATURE SETTINGS
# -----------------------------------------------------------------------------

# Enabled plugins (space-separated list)
# Available plugins: careportal, rawbg, iob, cob, basal, sage, cage, iage, bage
#                      pushover, maker, bridge, mmconnect, pump, openaps, loop
#                      food, bwp, treatmentnotify, bgnow, delta, direction
#                      upbat, timeago, devicestatus, errorcodes, ar2
#                      simplealarms, profile, boluscalc, basal, bolus
NS_ENABLE=careportal rawbg iob cob basal sage cage iage bage

# Default authentication role for unauthenticated users
# Options: readable, denied, status-only, or any valid role name
# - readable: anyone can view without token
# - denied: requires token for every visit
# - status-only: api-secret based login
NS_AUTH_DEFAULT_ROLES=denied

# Display units: mg/dl or mmol/L
NS_DISPLAY_UNITS=mg/dl

# -----------------------------------------------------------------------------
# ALARM SETTINGS
# -----------------------------------------------------------------------------

# BG thresholds (in mg/dl or mmol/L based on DISPLAY_UNITS)
NS_BG_HIGH=260
NS_BG_TARGET_TOP=180
NS_BG_TARGET_BOTTOM=80
NS_BG_LOW=55

# Alarm toggles (on/off)
NS_ALARM_URGENT_HIGH=on
NS_ALARM_HIGH=on
NS_ALARM_LOW=on
NS_ALARM_URGENT_LOW=on

# -----------------------------------------------------------------------------
# DISPLAY SETTINGS
# -----------------------------------------------------------------------------

# Time format: 12 or 24
NS_TIME_FORMAT=24

# Language code (en, de, fr, es, etc.)
NS_LANGUAGE=en

# Custom site title
NS_CUSTOM_TITLE=Nightscout

# -----------------------------------------------------------------------------
# ADVANCED SETTINGS (Optional)
# -----------------------------------------------------------------------------

# Theme: default, colors, colorblindfriendly
# NS_THEME=colors

# Scale Y axis: log, linear, log-dynamic
# NS_SCALE_Y=log

# Night mode: on or off
# NS_NIGHT_MODE=off

# Show raw BG: always, never, or noise
# NS_SHOW_RAWBG=never

# -----------------------------------------------------------------------------
# BRIDGE SETTINGS (Optional - for Dexcom Share integration)
# -----------------------------------------------------------------------------
# To pull data directly from Dexcom Share, add 'bridge' to NS_ENABLE
# and configure these:
# BRIDGE_USER_NAME=your_dexcom_username
# BRIDGE_PASSWORD=your_dexcom_password
# BRIDGE_SERVER=(blank for US, 'EU' for Europe)

# -----------------------------------------------------------------------------
# PUSHOVER SETTINGS (Optional - for push notifications)
# -----------------------------------------------------------------------------
# Add 'pushover' to NS_ENABLE and configure:
# PUSHOVER_API_TOKEN=your_api_token
# PUSHOVER_USER_KEY=your_user_key
